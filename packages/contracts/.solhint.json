{
  "extends": "solhint:recommended",
  "rules": {
    "code-complexity": ["error", 8],
    "compiler-version": ["error", "^0.8.19"],
    "func-visibility": ["warn", { "ignoreConstructors": true }],
    "max-line-length": ["error", 120],
    "not-rely-on-time": "off",
    "prettier/prettier": "off"
  }
}
