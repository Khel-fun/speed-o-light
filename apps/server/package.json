{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown && mkdir -p speed_o_light && cp -r ../../packages/circuits/speed_o_light/target speed_o_light/",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.mjs"
  },
  "dependencies": {
    "@hono/trpc-server": "^0.4.0",
    "@speed-o-light/api": "workspace:*",
    "@speed-o-light/db": "workspace:*",
    "@speed-o-light/env": "workspace:*",
    "@trpc/server": "catalog:",
    "@aztec/bb.js": "0.84.0",
    "@noir-lang/acvm_js": "1.0.0-beta.6",
    "@noir-lang/noir_js": "1.0.0-beta.6",
    "@noir-lang/noirc_abi": "1.0.0-beta.6",
    "cors": "^2.8.5",
    "dotenv": "catalog:",
    "express": "^5.1.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@speed-o-light/config": "workspace:*",
    "@types/cors": "^2.8.17",
    "@types/express": "catalog:",
    "@types/node": "catalog:",
    "tsdown": "^0.21.9",
    "tsx": "^4.19.2",
    "typescript": "catalog:"
  },
  "trustedDependencies": [
    "supabase"
  ]
}
