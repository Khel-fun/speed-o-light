# --- Postgres / Supabase (copy into apps/server/.env) ---
#
# DATABASE_URL — Transaction pooler (app runtime). Port 6543 + pgbouncer + ssl.
# DIRECT_URL     — Prisma CLI (`pnpm db push`). Session pooler :5432 on the same
#   pooler host (IPv4-friendly). Avoid `db.<ref>.supabase.co:5432` if you see P1001 (IPv6-only).
#
# Use the same database password in both lines (from Supabase → Connect). URL-encode special chars in the password.
# P1000 = wrong password — reset under Project Settings → Database.

DATABASE_URL=postgresql://postgres.gjxqqlgmsstmezvgracl:REPLACE_WITH_DB_PASSWORD@aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require
DIRECT_URL=postgresql://postgres.gjxqqlgmsstmezvgracl:REPLACE_WITH_DB_PASSWORD@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres?sslmode=require

CORS_ORIGIN=http://localhost:3001
NODE_ENV=development

KURIER_URL=https://api-testnet.kurier.xyz/api/v1
KURIER_API=
# 84532 for Base Sepolia, 8453 for Base Mainnet
KURIER_CHAIN_ID=84532

SIGNING_PRIVATE_KEY=

REDIS_URL=redis://localhost:6379
LOG_LEVEL=info
